# Production environment template — copy to secrets manager / host .env
# NEVER commit real values to git.

# --- Core ---
ENVIRONMENT=production
AUTH_REQUIRED=true
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM

# --- Database ---
DATABASE_URL=postgresql://USER:PASSWORD@db-host:5432/terraforge

# --- Stores ---
JOB_STORE_BACKEND=postgres
INGEST_STORE_BACKEND=postgres
AUTH_STORE_BACKEND=postgres
STAC_CATALOG_BACKEND=postgres
STORAGE_BACKEND=minio
MODEL_REGISTRY_BACKEND=memory

# --- MinIO / S3-compatible ---
MINIO_ENDPOINT=minio.internal:9000
MINIO_ACCESS_KEY=REPLACE_ME
MINIO_SECRET_KEY=REPLACE_ME
MINIO_BUCKET=terraforge
MINIO_SECURE=true

# --- Redis / Celery ---
REDIS_URL=redis://redis.internal:6379/0

# --- Gemini LLM (rotate if exposed) ---
LLM_PROVIDER=gemini
LLM_API_KEY=REPLACE_WITH_NEW_ROTATED_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RPM=30
# LLM_FORCE_STUB=false

# --- Observability ---
SENTRY_DSN=REPLACE_ME