# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=terraforge
DB_USER=postgres
DB_PASSWORD=postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/terraforge

# Job store: memory | postgres | redis
JOB_STORE_BACKEND=postgres

# Auth
AUTH_REQUIRED=false
AUTH_STORE_BACKEND=postgres
JWT_SECRET=REPLACE_ME
JWT_EXPIRE_MINUTES=60

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
# Worker queues: default (kriging, deposit_model), gpu (classification), reports (jorc)

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=REPLACE_ME
MINIO_SECRET_KEY=REPLACE_ME

# Firebase
FIREBASE_PROJECT_ID=REPLACE_ME
FIREBASE_SERVICE_ACCOUNT_PATH=REPLACE_ME

# LLM — provider TBD
LLM_PROVIDER=gemini
LLM_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RPM=12
LLM_PROVIDER=
LLM_API_KEY=REPLACE_ME

# IPFS
IPFS_NODE_URL=http://localhost:5001

# Sentry
SENTRY_DSN=REPLACE_ME

# App
ENVIRONMENT=development
DEBUG=true
